{
  "version": "v0.1.28",
  "description": "第一章事件配置基础结构。v0.1.28 接入盗术、黑水与坊市风险事件池 MVP。",
  "required_event_fields": [
    "event_id",
    "title",
    "event_type",
    "chapter",
    "repeatable",
    "priority",
    "weight",
    "conditions",
    "choices"
  ],
  "optional_event_fields": [
    "month_min",
    "month_max",
    "cooldown_months",
    "risk_level",
    "route_tags",
    "npc_ids",
    "text",
    "auto_choice"
  ],
  "supported_condition_ops": [
    "==",
    "!=",
    ">",
    ">=",
    "<",
    "<=",
    "in",
    "not_in",
    "contains",
    "not_contains",
    "exists",
    "not_exists"
  ],
  "supported_effect_ops": [
    "set",
    "add",
    "min",
    "max",
    "append",
    "remove",
    "flag_on",
    "flag_off"
  ]
}
