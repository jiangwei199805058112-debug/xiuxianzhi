          {"field": "talisman_failure_risk", "op": "add", "value": -2, "summary": "符纸失灵风险-2"},
          {"field": "market_talisman_path_level", "op": "add", "value": 1, "summary": "坊市路线经验+1"}
        ]
      },
      {
        "choice_id": "keep_it",
