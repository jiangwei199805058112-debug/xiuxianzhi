[
  {
    "event_id": "EVT_CH1_POOL_MARKET_001_PRICE_SHIFT",
    "title": "坊市涨价",
    "event_type": "market_price_shift",
    "chapter": 1,
    "repeatable": true,
    "priority": 30,
    "weight": 3,
    "month_min": 3,
    "month_max": 12,
    "cooldown_months": 2,
    "risk_level": "low",
    "route_tags": ["market_talisman"],
    "npc_ids": [],
    "text": "坊市今日人声嘈杂，符纸、药粉、低阶阵盘都比往常贵了一截。摊主只说近来外门弟子也在囤货。",
    "auto_choice": "delay_purchase",
    "conditions": [
      {
        "any": [
          {"field": "monthly_action_counts.market", "op": ">=", "value": 1},
          {"field": "market_mastery", "op": ">=", "value": 8}
        ]
      }
    ],
    "choices": [
      {
        "choice_id": "delay_purchase",
        "label": "暂缓采购",
        "effects": [
          {"field": "market_dependency_level", "op": "add", "value": 1, "summary": "外物依赖压力+1"},
          {"field": "market_talisman_path_level", "op": "add", "value": 1, "summary": "坊市路线经验+1"},
          {"field": "route_tags", "op": "append", "value": "market_talisman", "summary": "记录坊市符箓路线标记"}
        ]
      },
      {
        "choice_id": "buy_anyway",
        "label": "照买不误",
        "effects": [
          {"field": "spirit_stones", "op": "add", "value": -2, "summary": "灵石-2"},
          {"field": "market_dependency_level", "op": "add", "value": 4, "summary": "外物依赖+4"}
        ]
      }
    ]
  },
  {
